# iOS Xcode project should be tracked (monorepo)
!ios/*.xcodeproj/
!ios/*.xcworkspace/

# Xcode per-user junk (ignore everywhere, including ios/)
**/*.xcodeproj/project.xcworkspace/
**/*.xcodeproj/xcuserdata/
**/*.xcworkspace/xcuserdata/
**/*.xcuserdatad/

# Logs and debug artifacts
*.log
*.dSYM/

# Editor/IDE
.vscode/
.idea/

# Environment/secrets (keep local only)
.env
.env.*
!.env.example

# Local iOS secrets (do not commit)
ios/**/Secrets.plist
Secrets.plist
Secrets.plist
*.xcuserstate
